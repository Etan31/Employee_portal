{
  "buildCommand": "pnpm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "server/api/index.js": {
      "includeFiles": "server/**"
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/server/api/index.js"
    },
    {
      "source": "/api/:path*",
      "destination": "/server/api/index.js"
    }
  ]
}